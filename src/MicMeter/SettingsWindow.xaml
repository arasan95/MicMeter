<Window x:Class="MicMeter.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MicMeter 設定" Icon="Assets/app-icon.png" Width="500" Height="790"
        MinWidth="450" MinHeight="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#FF0D131A" Foreground="#FFE7EEF6">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE7EEF6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF1A2632" />
            <Setter Property="Foreground" Value="#FFEAF2FA" />
            <Setter Property="BorderBrush" Value="#FF344A5F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF17212C" />
            <Setter Property="Foreground" Value="#FFEAF2FA" />
            <Setter Property="BorderBrush" Value="#FF344A5F" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF17212C" />
            <Setter Property="Foreground" Value="#FFEAF2FA" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#FF111A23" />
            <Setter Property="Foreground" Value="#FFEAF2FA" />
            <Setter Property="BorderBrush" Value="#FF344A5F" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFEAF2FA" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFDCE7F1" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF111A23" />
            <Setter Property="Foreground" Value="#FFEAF2FA" />
            <Setter Property="BorderBrush" Value="#FF344A5F" />
            <Setter Property="Padding" Value="6,3" />
        </Style>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="MicMeter 設定" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="入力デバイス" FontWeight="SemiBold" Margin="0,0,0,5" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="72" />
                </Grid.ColumnDefinitions>
                <ListBox x:Name="DeviceListBox" Height="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Content="{Binding Name}" Margin="3" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Button Content="↑ 上へ" Height="30" Margin="0,0,0,8" Click="MoveUpButton_Click" />
                    <Button Content="↓ 下へ" Height="30" Click="MoveDownButton_Click" />
                </StackPanel>
            </Grid>
            <TextBlock Text="一覧の上から順に表示されます。項目を選び、上下ボタンで表示順を変更できます。"
                       Foreground="#FF8FA4B8" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="大きさ" FontWeight="SemiBold" />
                <Slider x:Name="ScaleSlider" Minimum="0.75" Maximum="2" TickFrequency="0.05" IsSnapToTickEnabled="True" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="透明度" FontWeight="SemiBold" />
                <Slider x:Name="OpacitySlider" Minimum="0.35" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="表示位置" FontWeight="SemiBold" Margin="0,0,0,5" />
                <ComboBox x:Name="PlacementComboBox" Height="30" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="セグメント数" FontWeight="SemiBold" Margin="0,0,0,5" />
                <ComboBox x:Name="SegmentCountComboBox" Height="30">
                    <ComboBoxItem Content="12" />
                    <ComboBoxItem Content="16" />
                    <ComboBoxItem Content="20" />
                    <ComboBoxItem Content="24" />
                    <ComboBoxItem Content="30" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="メーター方向" FontWeight="SemiBold" Margin="0,0,0,5" />
                <ComboBox x:Name="OrientationComboBox" Height="30">
                    <ComboBoxItem Content="横型" Tag="Horizontal" />
                    <ComboBoxItem Content="縦型" Tag="Vertical" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="テーマ" FontWeight="SemiBold" Margin="0,0,0,5" />
                <ComboBox x:Name="ThemeComboBox" Height="30">
                    <ComboBoxItem Content="Midnight Glass" Tag="MidnightGlass" />
                    <ComboBoxItem Content="Flat Black（角丸なし）" Tag="FlatBlack" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="5">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="言語" VerticalAlignment="Center" />
                <ComboBox x:Name="UiLanguageComboBox" Grid.Column="1" Height="30"
                          SelectionChanged="UiLanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="日本語" Tag="Japanese" />
                    <ComboBoxItem Content="English" Tag="English" />
                </ComboBox>
            </Grid>
            <CheckBox x:Name="TopmostCheckBox" Content="常に手前に表示" Margin="0,4" />
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="全ミュート・ホットキー" VerticalAlignment="Center" />
                <Button x:Name="HotkeyButton" Grid.Column="1" Height="32"
                        HorizontalContentAlignment="Left" Padding="10,0"
                        Click="HotkeyButton_Click" />
            </Grid>
            <TextBlock Text="表示項目" FontWeight="SemiBold" Margin="0,14,0,5" />
            <WrapPanel>
                <CheckBox x:Name="ShowDeviceNameCheckBox" Content="デバイス名" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowLevelTextCheckBox" Content="dB数値" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowStatusTextCheckBox" Content="状態文字" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowMuteControlCheckBox" Content="ミュート操作" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowListeningControlCheckBox" Content="リスニング操作" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowPeakHoldCheckBox" Content="ピークホールド" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowClippingWarningCheckBox" Content="CLIP警告" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowTrayMeterCheckBox" Content="トレイメーター" Width="130" Margin="0,3" />
                <CheckBox x:Name="PlayMuteSoundsCheckBox" Content="ミュート通知音" Width="130" Margin="0,3" />
                <CheckBox x:Name="ShowMuteOverlayCheckBox" Content="ミュート表示" Width="130" Margin="0,3" />
            </WrapPanel>
            <Button Content="ミュート表示の位置を調整" Height="32" Margin="0,8,0,0"
                    HorizontalAlignment="Left" Click="MuteOverlayPlacementButton_Click" />
            <TextBlock Text="メーターバーの色と切替位置" FontWeight="SemiBold" Margin="0,14,0,5" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="125" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="36" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>
                <TextBlock Text="低レベル" VerticalAlignment="Center" />
                <Button x:Name="LowColorButton" Grid.Column="1" Tag="Low" Click="ColorButton_Click" />

                <TextBlock Grid.Row="1" Text="中レベル" VerticalAlignment="Center" />
                <Button x:Name="MidColorButton" Grid.Row="1" Grid.Column="1" Tag="Mid" Click="ColorButton_Click" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="中色へ切替 (dB)" VerticalAlignment="Center" Margin="10,0,0,0" />
                <TextBox x:Name="MidThresholdTextBox" Grid.Row="1" Grid.Column="3" Height="28" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2" Text="高レベル" VerticalAlignment="Center" />
                <Button x:Name="HighColorButton" Grid.Row="2" Grid.Column="1" Tag="High" Click="ColorButton_Click" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="高色へ切替 (dB)" VerticalAlignment="Center" Margin="10,0,0,0" />
                <TextBox x:Name="HighThresholdTextBox" Grid.Row="2" Grid.Column="3" Height="28" VerticalContentAlignment="Center" />
            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="6" Margin="0,12,0,0" Foreground="#FF8FA4B8" TextWrapping="Wrap"
                   Text="細くリサイズすると文字は自動で隠れ、ミュートとリスニングは点表示になります。耳ボタンはヘッドホン使用を推奨します。" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="90" Margin="0,0,10,0" Click="CancelButton_Click" />
            <Button Content="保存" Width="90" IsDefault="True" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
