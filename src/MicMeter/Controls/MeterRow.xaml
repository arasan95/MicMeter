<UserControl x:Class="MicMeter.Controls.MeterRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MicMeter.Controls">
    <Grid>
        <Border x:Name="HorizontalBorder" BorderThickness="1" BorderBrush="Transparent"
                Background="#0AFFFFFF" CornerRadius="8" Padding="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HorizontalControlsColumn" Width="68" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="HorizontalValueColumn" Width="80" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="HorizontalMuteButton" Width="31" Height="31"
                            Style="{StaticResource OverlayButtonStyle}" ToolTip="このマイクをミュート"
                            Click="MuteButton_Click">
                        <TextBlock x:Name="HorizontalMicrophoneGlyph" Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>
                    <Button x:Name="HorizontalListenButton" Width="31" Height="31"
                            Style="{StaticResource OverlayButtonStyle}" ToolTip="既定の出力でこのマイクを聴く（ヘッドホン推奨）"
                            Click="ListenButton_Click">
                        <TextBlock Text="&#xE7F6;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>
                <Grid Grid.Column="1" Margin="2,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="HorizontalNameRow" Height="15" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="HorizontalDeviceNameText" Foreground="#FFB7C0C8" FontSize="9.5"
                               TextTrimming="CharacterEllipsis" />
                    <controls:SegmentMeter x:Name="HorizontalMeter" Grid.Row="1" Margin="0,2,0,1"
                                           VerticalAlignment="Stretch" LevelDb="-60" PeakDb="-60" />
                </Grid>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock x:Name="HorizontalLevelText" Text="-60.0 dB" Foreground="#FFF4F6F8"
                               FontFamily="Consolas" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Right" />
                    <TextBlock x:Name="HorizontalStatusText" Text="LIVE" Foreground="#FF34D36B"
                               FontSize="9" FontWeight="Bold" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="VerticalBorder" Visibility="Collapsed" BorderThickness="1" BorderBrush="Transparent"
                Background="#0AFFFFFF" CornerRadius="9" Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="VerticalNameRow" Height="28" />
                    <RowDefinition Height="*" />
                    <RowDefinition x:Name="VerticalLevelRow" Height="22" />
                    <RowDefinition x:Name="VerticalStatusRow" Height="18" />
                    <RowDefinition x:Name="VerticalControlsRow" Height="38" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="VerticalDeviceNameText" Foreground="#FFB7C0C8" FontSize="9.5"
                           TextTrimming="CharacterEllipsis" TextAlignment="Center" ToolTipService.ShowDuration="10000" />
                <controls:SegmentMeter x:Name="VerticalMeter" Grid.Row="1" Width="27"
                                       HorizontalAlignment="Center" LevelDb="-60" PeakDb="-60"
                                       Orientation="Vertical" />
                <TextBlock x:Name="VerticalLevelText" Grid.Row="2" Text="-60.0 dB" Foreground="#FFF4F6F8"
                           FontFamily="Consolas" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" />
                <TextBlock x:Name="VerticalStatusText" Grid.Row="3" Text="LIVE" Foreground="#FF34D36B"
                           FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" />
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="VerticalMuteButton" Width="34" Height="32"
                            Style="{StaticResource OverlayButtonStyle}" ToolTip="このマイクをミュート"
                            Click="MuteButton_Click">
                        <TextBlock x:Name="VerticalMicrophoneGlyph" Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    </Button>
                    <Button x:Name="VerticalListenButton" Width="34" Height="32"
                            Style="{StaticResource OverlayButtonStyle}" ToolTip="既定の出力でこのマイクを聴く（ヘッドホン推奨）"
                            Click="ListenButton_Click">
                        <TextBlock Text="&#xE7F6;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="CompactBorder" Visibility="Collapsed" BorderThickness="1" BorderBrush="Transparent"
                Background="#0AFFFFFF" CornerRadius="6" Padding="2,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="CompactMuteColumn" Width="18" />
                    <ColumnDefinition x:Name="CompactListenColumn" Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="CompactMuteButton" Width="16" Height="16"
                        VerticalAlignment="Center"
                        Style="{StaticResource OverlayButtonStyle}" ToolTip="このマイクをミュート"
                        Click="MuteButton_Click">
                    <Ellipse x:Name="CompactMuteDot" Width="8" Height="8" Fill="#FF34D36B" />
                </Button>
                <Button x:Name="CompactListenButton" Grid.Column="1" Width="16" Height="16"
                        VerticalAlignment="Center"
                        Style="{StaticResource OverlayButtonStyle}" ToolTip="このマイクをリスニング"
                        Click="ListenButton_Click">
                    <Ellipse x:Name="CompactListenDot" Width="8" Height="8" Fill="#FF55616B" />
                </Button>
                <controls:SegmentMeter x:Name="CompactMeter" Grid.Column="2"
                                       Height="10" Margin="2,0,0,0" VerticalAlignment="Center"
                                       LevelDb="-60" PeakDb="-60" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
