<Window x:Class="MicMeter.MuteNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MicMeter mute status" Icon="Assets/app-icon.png"
        Width="330" Height="104" MinWidth="260" MinHeight="84"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" ShowActivated="False"
        Topmost="True" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border x:Name="Shell"
            Margin="8" Padding="18,12"
            Background="#F20B1016" BorderBrush="#FFFF4961" BorderThickness="2"
            CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="18" ShadowDepth="3" Opacity="0.7" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Width="44" Height="44" CornerRadius="22"
                    Background="#35FF4961" BorderBrush="#FFFF4961" BorderThickness="1">
                <TextBlock Text="×" Foreground="#FFFF5D73" FontSize="34" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-5,0,0" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="MIC MUTED" Foreground="#FFFFF4F5"
                           FontSize="22" FontWeight="Bold" />
                <TextBlock x:Name="DetailText" Text="Microphone is muted" Foreground="#FFB8C3CE"
                           FontSize="12" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
