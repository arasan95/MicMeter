<Window x:Class="MicMeter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MicMeter.Controls"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="MicMeter" Icon="Assets/app-icon.png"
        Width="320" Height="64"
        MinWidth="80" MinHeight="44"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False" Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp">
    <Border x:Name="ShellBorder"
            Margin="8"
            Padding="8,7"
            BorderBrush="#6B34495E"
            BorderThickness="1"
            CornerRadius="14">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F216202B" Offset="0" />
                <GradientStop Color="#F20A0F16" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="16" ShadowDepth="3" Opacity="0.55" />
        </Border.Effect>
        <Grid>
            <StackPanel x:Name="RowsPanel" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <primitives:Thumb x:Name="ResizeThumb"
                              Width="18" Height="18"
                              HorizontalAlignment="Right" VerticalAlignment="Bottom"
                              Cursor="SizeNWSE"
                              DragDelta="ResizeThumb_DragDelta"
                              DragCompleted="ResizeThumb_DragCompleted">
                <primitives:Thumb.Template>
                    <ControlTemplate TargetType="primitives:Thumb">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </primitives:Thumb.Template>
            </primitives:Thumb>
        </Grid>
    </Border>
</Window>
